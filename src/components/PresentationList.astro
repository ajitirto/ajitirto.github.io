---
const presentations = [
  {
    title: "Linux Fundamental",
    event: "Educational",
    date: "4 May 2026",
    icon: "present_to_all",
    href: "http://ajitirto.github.io/linux-basic"
  },
  {
    title: "Micro-Frontends: Scalable Patterns",
    event: "JS Conf Asia",
    date: "August 22",
    icon: "settings_input_component",
    href: "#"
  },
  {
    title: "Zero-Trust Security in CI/CD Pipelines",
    event: "DevOps Days",
    date: "June 05",
    icon: "terminal",
    href: "#"
  }
];
---

<section class="mb-xl">
  <!-- Header with Lines -->
  <div class="flex items-center gap-4 mb-8">
    <div class="h-[1px] flex-grow bg-white/10"></div>
    <h2 class="font-label-caps text-xs text-white/40 uppercase tracking-widest font-medium">Presentations</h2>
    <div class="h-[1px] flex-grow bg-white/10"></div>
  </div>

  <!-- Cards Container -->
  <div class="flex flex-col gap-4">
    {presentations.map((p) => (
      <a 
        href={p.href} 
        target="_blank" 
        rel="noopener noreferrer"
        class="glass-card group relative flex items-center justify-between p-5 rounded-xl border border-white/5 bg-white/[0.02] transition-all duration-300 hover:bg-white/[0.06] hover:border-white/10 hover:-translate-y-1 no-underline"
      >
        <div class="flex items-center gap-5">
          <!-- Icon Box -->
          <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center shrink-0 border border-white/5 group-hover:border-white/20 transition-colors">
            <span class="material-symbols-outlined text-white/40 group-hover:text-white transition-colors">
              {p.icon}
            </span>
          </div>
          
          <!-- Text Content -->
          <div>
            <h4 class="text-base font-semibold text-white mb-0.5 group-hover:text-primary transition-colors">
              {p.title}
            </h4>
            <p class="text-sm text-white/40 font-medium">
              {p.event} <span class="mx-1 text-white/10">•</span> {p.date}
            </p>
          </div>
        </div>

        <!-- Arrow Icon -->
        <div class="hidden sm:flex items-center justify-center w-8 h-8 rounded-full bg-white/5 opacity-0 group-hover:opacity-100 group-hover:bg-white/10 transition-all duration-300 translate-x-[-10px] group-hover:translate-x-0">
          <span class="material-symbols-outlined text-white/60 text-sm">arrow_forward</span>
        </div>
      </a>
    ))}
  </div>
</section>
